# 開發環境呼叫的API URL
NEXT_PUBLIC_API_URL="https://ahop.localhost.com"
# 供應商平台的網址（開發）
NEXT_PUBLIC_VENDOR_URL="https://scm.localhost.com"
# 通用的API路徑 登入、更新token、登出．．等
NEXT_PUBLIC_API_PATH="api"
# 供應商平台使用的API路徑
NEXT_PUBLIC_VND_API_PATH="api-vendor"
# local storage 使用者的key
